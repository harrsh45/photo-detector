# Server Configuration
PORT=3000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/photo-detector

# JWT Authentication
JWT_SECRET=your_jwt_secret_key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Sightengine AI Detection
SIGHTENGINE_API_USER=your_sightengine_api_user
SIGHTENGINE_API_SECRET=your_sightengine_api_secret

# DeepAI Configuration
DEEPAI_API_KEY=your_deepai_api_key
USE_DEEPAI=false

# Clarifai Configuration
CLARIFAI_API_KEY=your_clarifai_api_key

# Upload Configuration
UPLOAD_PRESET=your_cloudinary_upload_preset